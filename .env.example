# 数据库
DATABASE_URL=postgresql://user:pass@localhost:5432/ai_fate

# 缓存 (本地开发用 redis://, 生产用 Upstash REST URL)
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# 微信开放平台
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=

# AI 服务
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=2592000

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fate-gate-public
R2_PUBLIC_URL=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# 功能开关
NEXT_PUBLIC_ENABLE_MOCK=true
NEXT_PUBLIC_ENABLE_TIME_GUESS=true
