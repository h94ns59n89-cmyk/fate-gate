{
  "name": "fate-gate",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "description": "AI命理人格系统 - 将传统八字命理转化为现代人格认知工具",
  "scripts": {
    "dev": "next dev",
    "dev:sync": "pwsh -NoProfile -File auto-sync.ps1",
    "build": "next build",
    "vercel-build": "prisma generate --schema=prisma/schema.postgres.prisma && prisma db push --schema=prisma/schema.postgres.prisma && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "electron:dev": "next build && electron .",
    "electron:build": "next build && node scripts/prep-standalone.mjs && electron-builder",
    "electron:build:dir": "next build && node scripts/prep-standalone.mjs && electron-builder --win --dir",
    "lint": "next lint && prettier --check .",
    "lint:fix": "next lint --fix && prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest",
    "test:run": "vitest --run",
    "verify:internal": "npm run typecheck && npm run test:run && npm run build",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:backfill-mbti": "tsx scripts/backfill-mbti.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "build": {
    "appId": "com.xingyu.app",
    "productName": "星隅",
    "directories": {
      "output": "release"
    },
    "files": [
      ".next/static/**/*",
      "public/**/*",
      "electron/**/*",
      "prisma/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": ".next/standalone",
        "filter": [
          "**/*",
          "!**/node_modules/**"
        ]
      },
      {
        "from": ".next/standalone_nm",
        "to": ".next/standalone/node_modules"
      },
      {
        "from": "prisma/",
        "to": "prisma/"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/favicon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/favicon.ico"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "星隅",
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "installerHeaderIcon": "public/favicon.ico",
      "installerHeader": "public/installer-header.bmp"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@sentry/nextjs": "10.56.0",
    "@types/jspdf": "1.3.3",
    "@vercel/og": "^0.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dayjs": "^1.11.0",
    "fast-xml-parser": "5.8.0",
    "html2canvas": "1.4.1",
    "jose": "6.2.3",
    "jspdf": "4.2.1",
    "lucide-react": "^0.400.0",
    "lunar-javascript": "^1.6.5",
    "next": "15.5.18",
    "openai": "6.37.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.0",
    "swr": "^2.2.0",
    "tailwind-merge": "^2.5.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/typography": "^0.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@upstash/redis": "^1.34.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.0",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
